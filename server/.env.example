# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────
# Supabase: Project Settings → Database → Connection string → URI.
#
#   Local development : either the direct connection (:5432) or the
#                       transaction pooler (:6543) works.
#   Cloud hosting     : use the TRANSACTION POOLER (:6543). The direct
#     (Railway, etc.)   connection is IPv6-only and times out from many
#                       hosting providers — the pooler is IPv4-reachable.
#
# Pooler URI looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:6543/postgres

# ── Auth ──────────────────────────────────────────────────────────────────
# Long random string used to sign session JWTs.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Deployed origin in production (e.g. https://dispo-chat.up.railway.app).
# Leave blank in dev — web runs on :5173 and proxies /api to :3001.
PUBLIC_ORIGIN=

# ── Seed (optional) ───────────────────────────────────────────────────────
# Used only by `npm run seed` for local development. If unset, safe
# defaults are used. `npm run seed` refuses to run when NODE_ENV=production.
SEED_EMAIL=dispatcher@dispo-chat.local
SEED_PASSWORD=devpassword
