# Copy to .env and fill in.
# For Supabase: Settings → Database → "Connection string" → URI (port 5432, NOT the 6543 pooler).
DATABASE_URL=postgresql://postgres:password@db.your-project-ref.supabase.co:5432/postgres

# Random long string used to sign session JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-string

# In production, set to your deployed origin (e.g. https://dispo-chat.up.railway.app)
# In dev, leave blank — the server runs on :3001 and web on :5173 via Vite proxy.
PUBLIC_ORIGIN=

PORT=3001
NODE_ENV=development
