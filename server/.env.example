# Copy this file to .env and fill in the values.

# ── Database ──────────────────────────────────────────────────────────────
# Supabase: Project Settings → Database → Connection string → URI.
#
#   Local development : either the direct connection (:5432) or the
#                       transaction pooler (:6543) works.
#   Cloud hosting     : use the TRANSACTION POOLER (:6543). The direct
#     (Railway, etc.)   connection is IPv6-only and times out from many
#                       hosting providers — the pooler is IPv4-reachable.
#
# Pooler URI looks like:
#   postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.your-project-ref:password@aws-0-your-region.pooler.supabase.com:6543/postgres

# ── Auth ──────────────────────────────────────────────────────────────────
# Long random string used to sign session JWTs.
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# ── Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Deployed origin in production (e.g. https://dispo-chat.up.railway.app).
# Leave blank in dev — web runs on :5173 and proxies /api to :3001.
PUBLIC_ORIGIN=

# ── Realtime / horizontal scaling (optional) ──────────────────────────────
# Socket.IO keeps each client's connection on a single API instance. To run
# MORE THAN ONE instance behind a load balancer, set REDIS_URL so all instances
# share realtime state through the Redis adapter — otherwise an event emitted on
# one instance won't reach clients connected to another.
#
#   Local dev / single instance : leave blank (in-memory adapter, no Redis).
#   Multi-instance production    : REQUIRED. Point at a managed Redis.
#
# Format: redis://[:password@]host:port  (use rediss:// for TLS).
#   e.g. redis://default:password@redis.railway.internal:6379
#
# Production safety: if REDIS_URL is SET but Redis can't be reached, the server
# now ABORTS startup in production (NODE_ENV=production) instead of silently
# degrading to the in-memory adapter. In dev it warns and falls back. With
# REDIS_URL unset in production the server runs single-instance and logs a
# warning that multi-instance realtime needs Redis.
REDIS_URL=

# ── Preview job queue (optional) ──────────────────────────────────────────
# Where image-preview background jobs run.
#   memory (default) : in-process queue. Fast, but jobs queued at the moment the
#                      process exits are lost (recover them with the backfill
#                      script: `npm run backfill:previews`).
#   redis            : reserved for a durable BullMQ-backed queue (not shipped
#                      yet — currently warns once and falls back to memory).
PREVIEW_QUEUE_DRIVER=memory

# ── Preview backfill (maintenance script, optional tuning) ────────────────
# `npm run backfill:previews` generates previews for older image attachments
# that have none. Tune per invocation; rerun until it reports candidates: 0.
# BACKFILL_BATCH=500          # rows processed per run
# BACKFILL_CONCURRENCY=3      # parallel preview workers

# ── Attachment storage (Supabase Storage) ─────────────────────────────────
# Attachment files live in a PRIVATE Supabase Storage bucket — durable across
# deploys and shared across environments (local disk on Railway is ephemeral
# and gets wiped on every redeploy, which loses uploads).
#
# Setup (one time):
#   1. Supabase dashboard → Storage → New bucket → name "attachments",
#      keep it PRIVATE (do not make it public).
#   2. Project Settings → API:
#        SUPABASE_URL              = "Project URL"  (https://<ref>.supabase.co)
#        SUPABASE_SERVICE_ROLE_KEY = the "service_role" secret  ⚠ server-only,
#                                    never ship to the browser.
#   3. Set all three on Railway too (Variables tab).
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me-with-the-service-role-key
SUPABASE_STORAGE_BUCKET=attachments

# ── Seed (optional) ───────────────────────────────────────────────────────
# Used only by `npm run seed` for local development. If unset, safe
# defaults are used. `npm run seed` refuses to run when NODE_ENV=production.
SEED_EMAIL=dispatcher@dispo-chat.local
SEED_PASSWORD=devpassword
